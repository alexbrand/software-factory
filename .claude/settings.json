{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/setup.sh",
            "timeout": 300,
            "statusMessage": "Setting up development environment..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/pre-commit.sh",
            "if": "Bash(git commit*)",
            "timeout": 120,
            "statusMessage": "Running pre-commit checks..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/pre-push.sh",
            "if": "Bash(git push*)",
            "timeout": 300,
            "statusMessage": "Running pre-push checks..."
          }
        ]
      }
    ]
  }
}
